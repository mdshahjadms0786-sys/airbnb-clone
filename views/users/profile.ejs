<% layout('/layouts/boilerplate') %>

<div class="profile-container">
    <div class="profile-header">
        <div class="profile-avatar">
            <i class="fa-solid fa-user-circle"></i>
        </div>
        <div class="profile-info">
            <h1><%= profileUser.username %></h1>
            <p class="profile-email"><%= profileUser.email %></p>
            <% if(profileUser.bio) { %>
                <p class="profile-bio"><%= profileUser.bio %></p>
            <% } %>
            <p class="profile-joined">Member since <%= new Date(profileUser.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %></p>
        </div>
        <% if(currUser && currUser._id.equals(profileUser._id)) { %>
        <button class="btn btn-edit-profile" onclick="toggleEditForm()">
            <i class="fa-solid fa-pen"></i> Edit Profile
        </button>
        <% } %>
    </div>

    <% if(currUser && currUser._id.equals(profileUser._id)) { %>
    <div class="edit-profile-form" id="editProfileForm" style="display: none;">
        <form action="/users/<%= profileUser._id %>?_method=PUT" method="POST">
            <div class="mb-3">
                <label for="username" class="form-label">Username:</label>
                <input type="text" id="username" name="username" value="<%= profileUser.username %>" class="form-control" required>
            </div>
            <div class="mb-3">
                <label for="email" class="form-label">Email:</label>
                <input type="email" id="email" name="email" value="<%= profileUser.email %>" class="form-control" required>
            </div>
            <div class="mb-3">
                <label for="bio" class="form-label">Bio:</label>
                <textarea id="bio" name="bio" class="form-control" rows="3"><%= profileUser.bio || '' %></textarea>
            </div>
            <button type="submit" class="btn btn-save">Save Changes</button>
            <button type="button" class="btn btn-cancel" onclick="toggleEditForm()">Cancel</button>
        </form>
    </div>
    <% } %>

    <div class="profile-stats">
        <div class="stat-item">
            <span class="stat-number"><%= myListings.length %></span>
            <span class="stat-label">Listings</span>
        </div>
        <div class="stat-item">
            <span class="stat-number"><%= profileUser.wishlist ? profileUser.wishlist.length : 0 %></span>
            <span class="stat-label">Wishlists</span>
        </div>
    </div>

    <% if(myListings && myListings.length > 0) { %>
    <div class="profile-section">
        <h2><i class="fa-solid fa-home"></i> My Listings</h2>
        <div class="listings-grid">
            <% for(let listing of myListings) { %>
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="listing-card-wrapper">
                        <div class="listing-card-image">
                            <img src="<%= listing.images && listing.images.length > 0 ? listing.images[0].url : (listing.image?.url || 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=800') %>" alt="<%= listing.title %>" onerror="this.src='https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=800'">
                            <div class="card-overlay"></div>
                        </div>
                        <div class="listing-info">
                            <h3 class="listing-title"><%= listing.title %></h3>
                            <p class="listing-location"><%= listing.location %>, <%= listing.country %></p>
                            <p class="listing-price">₹<%= listing.price.toLocaleString('en-IN') %>/night</p>
                        </div>
                    </div>
                </a>
            <% } %>
        </div>
    </div>
    <% } else { %>
    <div class="profile-section">
        <h2><i class="fa-solid fa-home"></i> My Listings</h2>
        <p class="no-listings-text">No listings yet. <a href="/listings/new">Create your first listing!</a></p>
    </div>
    <% } %>

    <% if(profileUser.wishlist && profileUser.wishlist.length > 0) { %>
    <div class="profile-section">
        <h2><i class="fa-solid fa-heart"></i> Wishlist</h2>
        <div class="listings-grid">
            <% for(let listing of profileUser.wishlist) { %>
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="listing-card-wrapper">
                        <div class="listing-card-image">
                            <img src="<%= listing.images && listing.images.length > 0 ? listing.images[0].url : (listing.image?.url || 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=800') %>" alt="<%= listing.title %>" onerror="this.src='https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=800'">
                            <div class="card-overlay"></div>
                        </div>
                        <div class="listing-info">
                            <h3 class="listing-title"><%= listing.title %></h3>
                            <p class="listing-location"><%= listing.location %>, <%= listing.country %></p>
                            <p class="listing-price">₹<%= listing.price.toLocaleString('en-IN') %>/night</p>
                        </div>
                    </div>
                </a>
            <% } %>
        </div>
    </div>
    <% } %>
</div>

<script>
function toggleEditForm() {
    const form = document.getElementById('editProfileForm');
    form.style.display = form.style.display === 'none' ? 'block' : 'none';
}
</script>

<style>
.profile-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem;
}

.profile-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 2rem;
    background: linear-gradient(135deg, #f8f8f8 0%, #ffffff 100%);
    border-radius: 16px;
    margin-bottom: 2rem;
}

.profile-avatar {
    font-size: 5rem;
    color: #f3424d;
}

.profile-info {
    flex: 1;
}

.profile-info h1 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    color: #222;
}

.profile-email {
    color: #717171;
    margin: 0 0 0.5rem 0;
}

.profile-bio {
    color: #222;
    margin: 0 0 0.5rem 0;
}

.profile-joined {
    color: #999;
    font-size: 0.9rem;
    margin: 0;
}

.btn-edit-profile {
    padding: 0.75rem 1.5rem;
    background: #222;
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.btn-edit-profile:hover {
    background: #333;
}

.edit-profile-form {
    background: #f8f8f8;
    padding: 2rem;
    border-radius: 16px;
    margin-bottom: 2rem;
}

.btn-save {
    background: #f3424d;
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
}

.btn-cancel {
    background: #ddd;
    color: #222;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    margin-left: 0.5rem;
}

.profile-stats {
    display: flex;
    gap: 3rem;
    padding: 1.5rem;
    background: #ffffff;
    border: 1px solid #eee;
    border-radius: 12px;
    margin-bottom: 2rem;
}

.stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
}

.stat-number {
    font-size: 2rem;
    font-weight: 700;
    color: #222;
}

.stat-label {
    font-size: 0.9rem;
    color: #717171;
}

.profile-section {
    margin-bottom: 3rem;
}

.profile-section h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    color: #222;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.no-listings-text {
    text-align: center;
    padding: 2rem;
    background: #f8f8f8;
    border-radius: 12px;
    color: #717171;
}

.no-listings-text a {
    color: #f3424d;
}

@media (max-width: 768px) {
    .profile-header {
        flex-direction: column;
        text-align: center;
    }
    
    .profile-stats {
        justify-content: center;
    }
}
</style>