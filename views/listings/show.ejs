<% layout('layouts/boilerplate') %>

<%
const listingImages = listing.images && listing.images.length > 0 ? listing.images : (listing.image?.url ? [{url: listing.image.url, filename: listing.image.filename}] : []);
const mainImage = listingImages[0]?.url || 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=800';
const basePrice = listing.price || 0;
const cleaningFee = Math.round(basePrice * 0.1);
const serviceFee = Math.round(basePrice * 0.08);

var lat = null, lng = null;
if (listing.geometry && listing.geometry.coordinates && listing.geometry.coordinates.length === 2) {
    lng = listing.geometry.coordinates[0];
    lat = listing.geometry.coordinates[1];
} else if (listing.coordinates && listing.coordinates.length === 2) {
    lng = listing.coordinates[0];
    lat = listing.coordinates[1];
}
const hasValidCoords = (lat !== null && lng !== null && lat !== undefined && lng !== undefined && lat !== 0 && lng !== 0);
%>

<div class="show-page-container">
    <div class="show-content-wrapper">
        <div class="left-column">
            <div class="image-gallery">
                <div class="main-image-container" onclick="openLightbox(0)">
                    <img src="<%= mainImage %>" alt="<%= listing.title %>">
                </div>
                <% if(listingImages.length > 1) { %>
                <div class="thumbnail-grid">
                    <% listingImages.slice(1, 5).forEach((img, index) => { %>
                    <div class="thumbnail-item" onclick="openLightbox(<%= index + 1 %>)">
                        <img src="<%= img.url %>" alt="Image <%= index + 2 %>">
                    </div>
                    <% }) %>
                    <% if(listingImages.length > 5) { %>
                    <div class="thumbnail-item show-all-btn" onclick="openLightbox(0)">
                        <img src="<%= listingImages[4]?.url %>" alt="Show all">
                        <div class="show-all-overlay">
                            <i class="fa-solid fa-grid-2"></i>
                            <span>Show all <%= listingImages.length %> photos</span>
                        </div>
                    </div>
                    <% } %>
                </div>
                <% } %>
            </div>

            <div class="listing-details">
                <h1 class="listing-title"><%= listing.title %></h1>
                <p class="listing-meta">
                    <i class="fa-solid fa-location-dot"></i>
                    <%= listing.location %>, <%= listing.country %> ·
                    <i class="fa-solid fa-star" style="color: #222;"></i>
                    <%= listing.avgRating > 0 ? listing.avgRating.toFixed(1) : 'New' %>
                    <% if(listing.numReviews > 0) { %>(<%= listing.numReviews %> reviews)<% } %>
                </p>
                
                <div class="listing-stats">
                    <span><i class="fa-solid fa-users"></i> <%= listing.guests || 4 %> guests</span>
                    <span><i class="fa-solid fa-bed"></i> <%= listing.bedrooms || 1 %> bedroom</span>
                    <span><i class="fa-solid fa-couch"></i> <%= listing.beds || 1 %> bed</span>
                    <span><i class="fa-solid fa-bath"></i> <%= listing.bathrooms || 1 %> bath</span>
                </div>
            </div>

            <hr class="divider">
            
            <div class="host-card">
                <div class="host-avatar">
                    <% if(listing.owner && listing.owner.avatar) { %>
                        <img src="<%= listing.owner.avatar %>" alt="Host avatar" style="width:60px;height:60px;border-radius:50%;object-fit:cover;">
                    <% } else { %>
                        <i class="fa-solid fa-user-circle"></i>
                    <% } %>
                </div>
                <div class="host-info">
                    <h3>Hosted by <%= listing.hostName || listing.owner?.username || 'Wanderlust Host'%></h3>
                    <p><i class="fa-solid fa-calendar"></i> Member since <%= listing.owner && listing.owner.createdAt ? new Date(listing.owner.createdAt).getFullYear() : '2024' %></p>
                </div>
            </div>

            <hr class="divider">

            <div class="listing-description-box">
                <p><%= listing.description %></p>
            </div>

            <hr class="divider">
            
            <% if(listing.amenities && listing.amenities.length > 0) { %>
            <div class="amenities-section">
                <h2><i class="fa-solid fa-house-chimney"></i> What this place offers</h2>
                <div class="amenities-grid">
                    <% listing.amenities.forEach(amenity => { %>
                    <div class="amenity-item">
                        <% 
                        const amenityIcons = {
                            'WiFi': 'fa-wifi',
                            'AC': 'fa-snowflake',
                            'Heating': 'fa-fire',
                            'Kitchen': 'fa-utensils',
                            'Washer': 'fa-soap',
                            'Dryer': 'fa-dryer',
                            'Parking': 'fa-square-parking',
                            'Pool': 'fa-person-swimming',
                            'Gym': 'fa-dumbbell',
                            'TV': 'fa-tv',
                            'Iron': 'fa-iron',
                            'Hair Dryer': 'fa-blow-dryer',
                            'Workspace': 'fa-laptop',
                            'Hot Water': 'fa-droplet',
                            'Dedicated Workspace': 'fa-desktop',
                            'Crib': 'fa-baby',
                            'High Chair': 'fa-chair',
                            'Smoke Alarm': 'fa-fire-extinguisher',
                            'First Aid Kit': 'fa-kit-medical',
                            'Fire Extinguisher': 'fa-fire-extinguisher'
                        };
                        %>
                        <i class="fa-solid <%= amenityIcons[amenity] || 'fa-check' %>"></i>
                        <span><%= amenity %></span>
                    </div>
                    <% }) %>
                </div>
            </div>
            
            <hr class="divider">
            <% } %>
            
            <% if(listing.houseRules) { %>
            <div class="house-rules-section">
                <h2><i class="fa-solid fa-clipboard-list"></i> House Rules</h2>
                <div class="rules-grid">
                    <div class="rule-item">
                        <i class="fa-solid fa-clock"></i>
                        <span>Check-in: <%= listing.houseRules.checkIn || '3:00 PM' %></span>
                    </div>
                    <div class="rule-item">
                        <i class="fa-solid fa-clock"></i>
                        <span>Checkout: <%= listing.houseRules.checkOut || '11:00 AM' %></span>
                    </div>
                    <div class="rule-item">
                        <i class="fa-solid <%= listing.houseRules.petsAllowed ? 'fa-paw text-green' : 'fa-ban text-red' %>"></i>
                        <span><%= listing.houseRules.petsAllowed ? 'Pets allowed' : 'No pets' %></span>
                    </div>
                    <div class="rule-item">
                        <i class="fa-solid <%= listing.houseRules.smokingAllowed ? 'fa-smoking' : 'fa-smoking-ban text-red' %>"></i>
                        <span><%= listing.houseRules.smokingAllowed ? 'Smoking allowed' : 'No smoking' %></span>
                    </div>
                    <div class="rule-item">
                        <i class="fa-solid <%= listing.houseRules.eventsAllowed ? 'fa-party-horn' : 'fa-ban text-red' %>"></i>
                        <span><%= listing.houseRules.eventsAllowed ? 'Events allowed' : 'No events' %></span>
                    </div>
                </div>
                <% if(listing.houseRules.additionalRules) { %>
                <p class="additional-rules"><%= listing.houseRules.additionalRules %></p>
                <% } %>
            </div>
            
            <hr class="divider">
            <% } %>

            <div class="reviews-section">
                <h2><i class="fa-solid fa-star"></i> Reviews</h2>
                
                <% if(currUser) { %>
                <div class="add-review-form">
                    <h4>Leave a Review</h4>
                    <form action="/listings/<%= listing._id %>/reviews" method="POST" class="review-form">
                        <div class="star-rating">
                            <input type="radio" id="star5" name="review[rating]" value="5" required /><label for="star5">&#9733;</label>
                            <input type="radio" id="star4" name="review[rating]" value="4" /><label for="star4">&#9733;</label>
                            <input type="radio" id="star3" name="review[rating]" value="3" /><label for="star3">&#9733;</label>
                            <input type="radio" id="star2" name="review[rating]" value="2" /><label for="star2">&#9733;</label>
                            <input type="radio" id="star1" name="review[rating]" value="1" /><label for="star1">&#9733;</label>
                        </div>
                        <textarea name="review[comment]" rows="4" placeholder="Share your experience..." required></textarea>
                        <button type="submit" class="btn-submit">Submit Review</button>
                    </form>
                </div>
                <% } else { %>
                <p class="login-prompt"><a href="/login">Login</a> to leave a review</p>
                <% } %>

                <% if(listing.reviews && listing.reviews.length > 0) { %>
                <div class="reviews-grid">
                    <% for (review of listing.reviews){ %>
                    <div class="review-card">
                        <strong><i class="fa-solid fa-user"></i> <%= review.author?.username || 'Guest' %></strong>
                        <div style="margin: 5px 0;"><% for(let i=0; i<review.rating; i++){ %>⭐<% } %></div>
                        <p><%= review.comment %></p>
                        <% if(currUser && review.author && currUser._id.equals(review.author._id)) { %>
                        <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                            <button type="submit" class="btn-delete-review">Delete</button>
                        </form>
                        <% } %>
                    </div>
                    <% } %>
                </div>
                <% } else { %>
                <p class="no-reviews">No reviews yet. Be the first!</p>
                <% } %>
            </div>

            <% if(hasValidCoords) { %>
            <hr class="divider">
            <div class="map-section">
                <h3>📍 Location</h3>
                <div id="map"></div>
            </div>
            <% } %>
        </div>

        <div class="right-column">
            <% if(!currUser) { %>
            <div class="login-booking-notice">
                <a href="/login">Login</a> to book this property
            </div>
            <% } %>
            
            <div class="booking-card">
                <div class="booking-header">
                    <span class="price-value">₹<%= basePrice.toLocaleString("en-IN") %></span>
                    <span class="price-unit">/night</span>
                    <% if(listing.avgRating > 0) { %>
                    <span class="price-rating">
                        <i class="fa-solid fa-star"></i> <%= listing.avgRating.toFixed(1) %>
                    </span>
                    <% } %>
                </div>
                
                <form action="/bookings/<%= listing._id %>/book" method="POST" id="bookingForm" onsubmit="return validateBooking()">
                    <div class="date-inputs">
                        <div class="date-field">
                            <label>Check-in</label>
                            <input type="text" id="checkin" name="checkIn" placeholder="Add date" readonly required onclick="this.value=''" style="width:100%;border:none;outline:none;background:transparent;font-size:0.9rem;">
                        </div>
                        <div class="date-field">
                            <label>Checkout</label>
                            <input type="text" id="checkout" name="checkOut" placeholder="Add date" readonly required onclick="this.value=''" style="width:100%;border:none;outline:none;background:transparent;font-size:0.9rem;">
                        </div>
                    </div>
                    
                    <div class="guest-counter">
                        <div>
                            <label>Guests</label>
                        </div>
                        <div class="counter-controls">
                            <button type="button" onclick="updateGuests(-1)">−</button>
                            <span id="guestCount">1</span>
                            <button type="button" onclick="updateGuests(1)">+</button>
                        </div>
                        <input type="hidden" id="guestsInput" name="guests" value="1">
                    </div>
                    
                    <input type="hidden" name="pricePerNight" value="<%= basePrice %>">
                    <input type="hidden" name="cleaningFee" value="<%= cleaningFee %>">
                    <input type="hidden" name="serviceFee" value="<%= serviceFee %>">
                    <input type="hidden" name="totalNights" id="totalNights" value="0">
                    <input type="hidden" name="totalPrice" id="totalPriceInput" value="0">
                    
                    <div class="price-breakdown" id="priceBreakdown" style="display:none;">
                        <div class="price-row">
                            <span>₹<%= basePrice.toLocaleString("en-IN") %> × <span id="nightsCount">0</span> nights</span>
                            <span>₹<span id="nightsTotal">0</span></span>
                        </div>
                        <div class="price-row">
                            <span>Cleaning fee</span>
                            <span>₹<%= cleaningFee.toLocaleString("en-IN") %></span>
                        </div>
                        <div class="price-row">
                            <span>Service fee</span>
                            <span>₹<%= serviceFee.toLocaleString("en-IN") %></span>
                        </div>
                        <div class="price-row total-row">
                            <span>Total</span>
                            <span>₹<span id="totalPrice">0</span></span>
                        </div>
                    </div>
                    
                    <% if(currUser) { %>
                    <button type="submit" class="btn-reserve">Reserve</button>
                    <% } else { %>
                    <a href="/login" class="btn-reserve" style="display:block;text-align:center;text-decoration:none;">Login to Reserve</a>
                    <% } %>
                    
                    <p class="no-charge">You won't be charged yet</p>
                </form>
            </div>

            <% if(currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
            <div class="owner-actions">
                <a href="/listings/<%= listing._id %>/edit" class="btn btn-edit">✏️ Edit</a>
                <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
                    <button type="submit" class="btn btn-delete">🗑️ Delete</button>
                </form>
            </div>
            <% } %>
        </div>
    </div>
</div>

<div id="lightbox" class="lightbox" onclick="closeLightbox()">
    <button class="lightbox-close" onclick="closeLightbox()">×</button>
    <button class="lightbox-prev" onclick="event.stopPropagation(); changeImage(-1)">‹</button>
    <img id="lightbox-img" onclick="event.stopPropagation()">
    <button class="lightbox-next" onclick="event.stopPropagation(); changeImage(1)">›</button>
    <div class="lightbox-counter" id="lightboxCounter"></div>
</div>

<style>
.show-page-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
}

.show-content-wrapper {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 40px;
}

.left-column { min-width: 0; }

.right-column {
    position: sticky;
    top: 100px;
    height: fit-content;
}

.image-gallery {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 8px;
    border-radius: 16px;
    overflow: hidden;
}

.main-image-container { cursor: pointer; }
.main-image-container img {
    width: 100%;
    height: 400px;
    object-fit: cover;
}

.thumbnail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
}

.thumbnail-item {
    cursor: pointer;
    overflow: hidden;
}

.thumbnail-item img {
    width: 100%;
    height: 196px;
    object-fit: cover;
}

.show-all-btn { position: relative; }

.show-all-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 600;
}

.listing-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
}

.listing-meta { color: #717171; margin-bottom: 0.25rem; }
.listing-host { color: #717171; margin: 0.5rem 0; }

.listing-stats {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
    padding: 1rem;
    background: #f8f8f8;
    border-radius: 8px;
    font-size: 0.9rem;
}
.listing-stats span {
    display: flex;
    align-items: center;
    gap: 6px;
    color: #222;
}
.listing-stats i {
    color: #717171;
}

.host-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: #f8f8f8;
    border-radius: 12px;
}
.host-avatar {
    width: 60px;
    height: 60px;
    background: #e0e0e0;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}
.host-avatar i {
    font-size: 3rem;
    color: #717171;
}
.host-info h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
}
.host-info p {
    font-size: 0.85rem;
    color: #717171;
    margin: 0;
}

.amenities-section h2, .house-rules-section h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 8px;
}

.amenities-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
}
.amenity-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 1rem;
}
.amenity-item i {
    font-size: 1.25rem;
    width: 30px;
    color: #222;
}

.house-rules-section {}
.rules-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
}
.rule-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.95rem;
}
.rule-item i {
    width: 24px;
    color: #222;
}
.rule-item .text-green { color: #22c55e; }
.rule-item .text-red { color: #ef4444; }
.additional-rules {
    margin-top: 1rem;
    padding: 1rem;
    background: #f8f8f8;
    border-radius: 8px;
    color: #717171;
    font-size: 0.9rem;
}

.divider { border: none; border-top: 1px solid #ddd; margin: 1.5rem 0; }
.listing-description-box { line-height: 1.7; }

.reviews-section h2 { font-size: 1.25rem; font-weight: 600; display: flex; align-items: center; gap: 8px; }

.reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
}

.review-card {
    padding: 1rem;
    border: 1px solid #eee;
    border-radius: 8px;
}

.btn-delete-review {
    background: #ff4444;
    color: white;
    border: none;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 0.8rem;
    margin-top: 8px;
    cursor: pointer;
}

.no-reviews, .login-prompt {
    text-align: center;
    padding: 1.5rem;
    background: #f5f5f5;
    border-radius: 8px;
    color: #717171;
}

.login-prompt a { color: #f3424d; font-weight: 600; }

#map {
    height: 300px;
    border-radius: 12px;
}

.booking-card {
    border: 1px solid #ddd;
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
}

.booking-header {
    display: flex;
    align-items: baseline;
    gap: 5px;
    margin-bottom: 1.5rem;
}

.price-value { font-size: 1.5rem; font-weight: 700; }
.price-unit { color: #717171; }

.booking-form { display: flex; flex-direction: column; gap: 12px; }

.date-inputs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid #717171;
    border-radius: 8px;
    overflow: hidden;
}

.date-field { padding: 12px; }
.date-field:first-child { border-right: 1px solid #717171; }
.date-field label {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
}
.date-field input {
    width: 100%;
    border: none;
    outline: none;
    font-size: 0.9rem;
    background: transparent;
    color: #717171;
}

.guest-counter {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border: 1px solid #717171;
    border-radius: 8px;
    padding: 12px;
}

.guest-counter label { display: block; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; }
.guest-hint { font-size: 0.75rem; color: #717171; }

.counter-controls { display: flex; align-items: center; gap: 16px; }
.counter-controls button {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid #717171;
    background: white;
    font-size: 1.2rem;
    cursor: pointer;
}

.btn-reserve {
    background: linear-gradient(to right, #e91e63, #ff5722);
    color: white;
    border: none;
    padding: 14px;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
}

.price-breakdown { padding-top: 1rem; border-top: 1px solid #eee; }
.price-row {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    color: #717171;
}
.price-row.total-row {
    border-top: 1px solid #eee;
    margin-top: 8px;
    padding-top: 16px;
    font-weight: 700;
    color: #222;
}
.no-charge { text-align: center; font-size: 0.85rem; color: #717171; margin-top: 0.5rem; }

.login-booking-notice {
    background: #fff3cd;
    border: 1px solid #ffc107;
    padding: 12px 16px;
    border-radius: 8px;
    margin-bottom: 1rem;
    text-align: center;
    font-size: 0.9rem;
}

.login-booking-notice a {
    color: #f3424d;
    font-weight: 600;
    text-decoration: none;
}

.price-rating {
    margin-left: 10px;
    font-size: 0.9rem;
    color: #222;
}

.price-rating i {
    color: #222;
}

.owner-actions { display: flex; gap: 1rem; margin-top: 1.5rem; }
.btn { flex: 1; padding: 12px; border-radius: 8px; font-weight: 500; text-align: center; text-decoration: none; border: none; }
.btn-edit { background: #222; color: white; }
.btn-delete { background: #ff4444; color: white; }

.star-rating { display: flex; flex-direction: row-reverse; gap: 4px; margin-bottom: 8px; }
.star-rating input { display: none; }
.star-rating label { font-size: 1.5rem; color: #ddd; cursor: pointer; }
.star-rating input:checked ~ label { color: #f5b301; }

.add-review-form {
    background: #f8f8f8;
    padding: 1.25rem;
    border-radius: 12px;
    margin: 1rem 0;
}
.add-review-form textarea { width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 8px; margin-bottom: 8px; }
.btn-submit { background: #222; color: white; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; }

.lightbox {
    display: none;
    position: fixed;
    z-index: 9999;
    inset: 0;
    background: rgba(0,0,0,0.95);
    align-items: center;
    justify-content: center;
}
.lightbox-content { max-width: 90%; max-height: 85vh; object-fit: contain; border-radius: 8px; }
.lightbox-close {
    position: absolute;
    top: 20px;
    right: 30px;
    font-size: 40px;
    color: white;
    background: none;
    border: none;
    cursor: pointer;
}
.lightbox-prev, .lightbox-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    font-size: 40px;
    color: white;
    background: rgba(0,0,0,0.5);
    border: none;
    padding: 20px 15px;
    border-radius: 8px;
    cursor: pointer;
}
.lightbox-prev { left: 20px; }
.lightbox-next { right: 20px; }
.lightbox-counter {
    position: absolute;
    bottom: 20px;
    color: white;
    font-size: 0.9rem;
}

@media (max-width: 1024px) {
    .show-content-wrapper { grid-template-columns: 1fr; }
    .right-column { position: static; }
}
@media (max-width: 768px) {
    .image-gallery { grid-template-columns: 1fr; }
    .main-image-container img { height: 280px; }
    .thumbnail-grid { grid-template-columns: repeat(4, 1fr); }
    .thumbnail-item img { height: 80px; }
    .show-all-overlay span { display: none; }
}
</style>

<script>
const basePrice = <%= basePrice %>;
const cleaningFee = <%= cleaningFee %>;
const serviceFee = <%= serviceFee %>;
let guestCount = 1;
let currentIndex = 0;
const images = <%- JSON.stringify(listingImages.map(img => img.url)) %>;

const checkinPicker = flatpickr("#checkin", {
    minDate: "today",
    dateFormat: "d M Y",
    altInput: true,
    altFormat: "d M Y",
    onChange: function(selectedDates, dateStr) {
        checkoutPicker.set("minDate", selectedDates[0]);
        updatePrice();
    }
});

const checkoutPicker = flatpickr("#checkout", {
    minDate: "today",
    dateFormat: "d M Y",
    altInput: true,
    altFormat: "d M Y",
    onChange: function(selectedDates, dateStr) {
        updatePrice();
    }
});

function updateGuests(change) {
    const max = <%= listing.guests || 4 %>;
    guestCount = Math.max(1, Math.min(max, guestCount + change));
    document.getElementById('guestCount').textContent = guestCount;
    document.getElementById('guestsInput').value = guestCount;
}

function updatePrice() {
    const checkin = checkinPicker.selectedDates[0];
    const checkout = checkoutPicker.selectedDates[0];
    if (checkin && checkout) {
        const nights = Math.ceil((checkout - checkin) / (1000 * 60 * 60 * 24));
        if (nights > 0) {
            const nightsTotal = nights * basePrice;
            const total = nightsTotal + cleaningFee + serviceFee;
            document.getElementById('nightsCount').textContent = nights;
            document.getElementById('nightsTotal').textContent = nightsTotal.toLocaleString('en-IN');
            document.getElementById('totalPrice').textContent = total.toLocaleString('en-IN');
            document.getElementById('totalNights').value = nights;
            document.getElementById('totalPriceInput').value = total;
            document.getElementById('priceBreakdown').style.display = 'block';
        }
    }
}

function validateBooking() {
    const checkin = checkinPicker.selectedDates[0];
    const checkout = checkoutPicker.selectedDates[0];
    
    if (!checkin || !checkout) {
        alert('Please select check-in and check-out dates');
        return false;
    }
    
    if (checkin >= checkout) {
        alert('Check-out date must be after check-in date');
        return false;
    }
    
    const guests = parseInt(document.getElementById('guestsInput').value) || 1;
    if (guests < 1) {
        alert('Please select at least 1 guest');
        return false;
    }
    
    return true;
}

function openLightbox(index) {
    currentIndex = index;
    document.getElementById('lightbox-img').src = images[currentIndex];
    document.getElementById('lightbox').style.display = 'flex';
    document.body.style.overflow = 'hidden';
    updateLightboxCounter();
}

function closeLightbox() {
    document.getElementById('lightbox').style.display = 'none';
    document.body.style.overflow = 'auto';
}

function changeImage(dir) {
    event.stopPropagation();
    currentIndex = (currentIndex + dir + images.length) % images.length;
    document.getElementById('lightbox-img').src = images[currentIndex];
    updateLightboxCounter();
}

function updateLightboxCounter() {
    document.getElementById('lightboxCounter').textContent = (currentIndex + 1) + ' / ' + images.length;
}

<% if(hasValidCoords) { %>
setTimeout(function() {
    if (document.getElementById('map')) {
        const map = L.map('map').setView([<%= lat %>, <%= lng %>], 13);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
        L.marker([<%= lat %>, <%= lng %>]).addTo(map);
    }
}, 500);
<% } %>

document.addEventListener('keydown', function(e) {
    if (document.getElementById('lightbox').style.display === 'flex') {
        if (e.key === 'ArrowLeft') changeImage(-1);
        if (e.key === 'ArrowRight') changeImage(1);
        if (e.key === 'Escape') closeLightbox();
    }
});
</script>